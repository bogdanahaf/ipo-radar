{
  "name": "ipo-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static IPO calendar and Telegram alert pipeline for GitHub Pages.",
  "scripts": {
    "refresh": "node scripts/refresh-data.js",
    "alert": "node scripts/send-alert.js",
    "alert:today:dry": "node scripts/send-alert.js --type today --dry-run",
    "alert:tomorrow:dry": "node scripts/send-alert.js --type tomorrow --dry-run",
    "alert:ping": "node scripts/send-alert.js --type ping",
    "alert:ping:dry": "node scripts/send-alert.js --type ping --dry-run",
    "alert:week:dry": "node scripts/send-alert.js --type week --dry-run",
    "serve:docs": "npx --yes http-server@14 ./docs -p 8765 -a 127.0.0.1 -c-1",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  }
}
